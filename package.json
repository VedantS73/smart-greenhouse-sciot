{
  "name": "smart-greenhouse",
  "version": "1.0.0",
  "description": "Smart Greenhouse IoT System with Real-time Dashboard",
  "main": "server.js",
  "scripts": {
    "postinstall": "cd frontend && npm install",
    "start": "concurrently --names \"Server,Client\" \"npm run server\" \"npm run client\"",
    "server": "node server.js",
    "client": "cd frontend && npm start",
    "start:python": "concurrently --names \"Publisher,Actuator,Planner\" \"python3 sensor_node/publisher.py\" \"python3 actuator_node/actuator_subscriber.py\" \"python3 planner/planner_node.py\"",
    "start:all": "concurrently --names \"Mosquitto,Python,Server\" \"mosquitto -c /etc/mosquitto/mosquitto.conf\" \"npm run start:python\" \"npm run start\"",
    "stop": "pkill -f publisher.py && pkill -f actuator_subscriber.py && pkill -f planner_node.py && pkill -f node",
    "dev": "concurrently --names \"Server,Client\" \"nodemon server.js\" \"cd frontend && npm start\""
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.5.4",
    "mqtt": "^4.3.7",
    "cors": "^2.8.5",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "concurrently": "^7.6.0",
    "nodemon": "^2.0.22"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
