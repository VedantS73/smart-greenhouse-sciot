# Copy this file to .env and fill in real values. .env is gitignored.

# --- MQTT (optional; defaults to localhost:1883) ---
# MQTT_BROKER=localhost
# MQTT_PORT=1883

# --- Node dashboard server (optional) ---
# PORT=5000
# HOST=0.0.0.0

# --- Twilio SMS Notifier (sms_notifier/sms_notifier.py) ---
# From your Twilio console. On a trial account you can only send to
# verified numbers, and TWILIO_FROM_NUMBER must be your Twilio number.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
# Minimum seconds between SMS for the same alert reason (default 120)
# SMS_COOLDOWN_SEC=120

# --- ThingSpeak Cloud Data Logger (cloud_logger/cloud_logger.py) ---
# Create a channel with fields: field1=temperature, field2=humidity,
# field3=light, field4=sound, field5=moisture, field6=motion.
# Then paste the channel's Write API Key below.
THINGSPEAK_WRITE_API_KEY=
# Minimum seconds between cloud writes (free tier is ~15s)
# THINGSPEAK_INTERVAL_SEC=15
